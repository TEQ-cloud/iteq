# Copy to .env and fill in.
DOMAIN=chat.example.com          # public DNS name; Caddy fetches the TLS cert automatically
DB_PASSWORD=change-me            # generate: openssl rand -hex 24
REDIS_PASSWORD=change-me         # generate: openssl rand -hex 24
ADMIN_USERS=yourname             # comma-separated; auto-approved accounts that approve others
ADMIN_SETUP_CODE=                # REQUIRED to claim an admin username: >=8 chars, not a placeholder
                                 # (generate: openssl rand -hex 16). Without it the api refuses
                                 # to hand out an admin account at all.
REDIS_MAXMEMORY=2gb              # cap for RAM chats
# Web Push (optional) — generate: docker compose run --rm api node src/vapid.js
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
# IMAGE_API=ghcr.io/teq-cloud/iteq-api:0.3.3-beta
# IMAGE_WEB=ghcr.io/teq-cloud/iteq-web:0.3.3-beta
# RETENTION_DAYS=7
# BIG_RETENTION_DAYS=3
# ACCOUNT_RETENTION_DAYS=180
